{
  "name": "rust-glancer-code",
  "displayName": "Rust Glancer",
  "description": "VS Code client for the rust-glancer language server.",
  "version": "0.1.0",
  "publisher": "rust-glancer",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:rust",
    "workspaceContains:Cargo.toml",
    "onCommand:rust-glancer.restartServer"
  ],
  "contributes": {
    "languages": [
      {
        "id": "rust",
        "aliases": [
          "Rust",
          "rust"
        ],
        "extensions": [
          ".rs"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "rust-glancer.restartServer",
        "title": "Rust Glancer: Restart Server"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Rust Glancer",
      "properties": {
        "rust-glancer.server.path": {
          "scope": "window",
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Path to the rust-glancer executable. When set, the extension runs this executable with the lsp subcommand."
        },
        "rust-glancer.server.extraEnv": {
          "scope": "window",
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional environment variables for the rust-glancer server process."
        },
        "rust-glancer.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Controls LSP protocol tracing for the rust-glancer client."
        }
      }
    }
  },
  "scripts": {
    "check": "tsc --noEmit -p .",
    "compile": "npm run check && esbuild ./src/extension.ts --bundle --external:vscode --format=cjs --platform=node --target=node18 --sourcemap --outfile=dist/extension.js",
    "watch": "tsc --noEmit -watch -p .",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.88.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.5"
  }
}